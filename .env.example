# Arithmo AI — Environment Variables
# Copy this file to .env.local and fill in your values

# Required: Groq API key for LLM inference
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: NVIDIA Nemotron API key
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here

# Optional: Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: Gemini model name
GEMINI_MODEL=gemini-3-flash-preview

# Optional: Freepik API key for image generation
FREEPIK_API_KEY=your_freepik_api_key_here

# Optional: SerpAPI key for real-time web search (RAG mode)
SERPAPI_KEY=your_serpapi_key_here

# Optional: Bing Web Search API key (used if SerpAPI is not set)
BING_SEARCH_API_KEY=your_bing_search_api_key_here
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# Required: MongoDB connection string (MongoDB Atlas recommended)
MONGODB_URI=

# Required: JWT secret for authentication (use a long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Optional limits
DAILY_IMAGE_LIMIT=3
MAX_MESSAGES_PER_CHAT=0
