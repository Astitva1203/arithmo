# Arithmo AI — Environment Variables
# Copy this file to .env.local and fill in your values

# Required: Groq API key for LLM inference
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: NVIDIA Nemotron API key
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here

# Optional: Freepik API key for image generation
FREEPIK_API_KEY=your_freepik_api_key_here

# Required: MongoDB connection string (MongoDB Atlas recommended)
MONGODB_URI=

# Required: JWT secret for authentication (use a long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
